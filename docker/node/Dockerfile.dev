FROM php:8.4-cli-alpine

# O plugin Vite do Wayfinder roda `php artisan wayfinder:generate` ao subir o
# dev server, então este container precisa de PHP além de Node.
RUN apk add --no-cache \
        nodejs \
        npm \
        libpng-dev \
        libzip-dev \
        oniguruma-dev \
        $PHPIZE_DEPS \
    && docker-php-ext-install pdo_mysql bcmath zip \
    && apk del $PHPIZE_DEPS

WORKDIR /var/www/html

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host"]
